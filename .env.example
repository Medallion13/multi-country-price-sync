# Local development defaults. Copy to .env and adjust.


# Postgres
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pricesync
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Prefect
# Inside compose network: prefect-server:4200. From host: localhost:4200.
PREFECT_API_URL=http://prefect-server:4200/api
PREFECT_SERVER_API_HOST=0.0.0.0
PREFECT_SERVER_API_PORT=4200

# External APIs
EXCHANGERATE_API_BASE=https://api.exchangerate.host
MOCK_WOOCOMMERCE_BASE=http://mock-woocommerce:8000

# App tuning
DRIFT_THRESHOLD_LOW=0.05
DRIFT_THRESHOLD_MEDIUM=0.10
DRIFT_THRESHOLD_CRITICAL=0.20
RAW_RETENTION_DAYS=30
ENABLE_CLEANUP=true

# Public deployment (production only)
PUBLIC_DOMAIN=prueba-pipelines.duckdns.org
BASIC_AUTH_USER=admin
# Generate with: docker run --rm caddy:2 caddy hash-password --plaintext 'yourpass'
BASIC_AUTH_PASS_HASH=

# DuckDNS
DUCKDNS_TOKEN=
